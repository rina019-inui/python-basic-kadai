        "import random\n",
        "\n",
        "var = random.randint(0,15)\n",
        "\n",
        "if var % 15== 0 :\n",
        "  print(\"FizzBuzz\")\n",
        "elif var % 5 == 0:\n",
        "  print(\"Buzz\")\n",
        "elif var % 3== 0:\n",
        "  print(\"Fizz\")\n",
        "else:\n",
        "  print(var)\n"
      ]
    }

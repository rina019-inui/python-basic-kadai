        "array = [\"水\", \"金\", \"地\", \"火\", \"木\", \"土\", \"天\", \"海\", \"冥\"]\n",
        "index = 0\n",
        "count = 0\n",
        "\n",
        "while count < 2:\n",
        "  while index < len(array):\n",
        "    print(array[index])\n",
        "    index += 1\n",
        "  count += 1\n",
        "  index = 0"
